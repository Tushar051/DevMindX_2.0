# Production Environment Variables for Vercel
# Copy these to your Vercel project settings

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/devmindx?retryWrites=true&w=majority
MONGODB_DB=devmindx
MONGODB_TLS=true

# AI Services
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Authentication
SESSION_SECRET=your_random_session_secret_here_min_32_chars
JWT_SECRET=your_jwt_secret_here

# OAuth (Optional - if using Google/GitHub login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://devmindx.vercel.app/api/auth/google/callback

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=https://devmindx.vercel.app/api/auth/github/callback

# URLs
FRONTEND_URL=https://devmindx.vercel.app
ALLOWED_ORIGINS=https://devmindx.vercel.app,https://devmindx.onrender.com

# Environment
NODE_ENV=production
PORT=5000

# Email (Optional - for verification emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Admin
ADMIN_KEY=your_admin_key_for_cron_jobs
