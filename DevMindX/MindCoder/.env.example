# ===========================================
# DevMindX Production Environment Variables
# ===========================================

# Server
NODE_ENV=production
PORT=5000

# MongoDB (Use MongoDB Atlas for production)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/devmindx?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_very_long_and_secure_random_string_here
JWT_EXPIRATION=86400000

# CORS - Add your frontend URL(s)
ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# Email (SendGrid or SMTP)
FORCE_EMAIL=true
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# OAuth - Google (Update callback URLs!)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-backend.railway.app/api/auth/google/callback

# OAuth - GitHub (Update callback URLs!)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=https://your-backend.railway.app/api/auth/github/callback

# AI APIs
GEMINI_API_KEY=your_gemini_api_key
TOGETHER_API_KEY=your_together_api_key
CHATGPT_API_KEY=your_openai_api_key
CLAUDE_API_KEY=your_anthropic_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key

# CodeSandbox (Optional)
CODESANDBOX_API_TOKEN=your_codesandbox_token
CODESANDBOX_API_VERSION=2023-07-01
