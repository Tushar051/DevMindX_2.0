{
    "name": "devmindx-front",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "DevMindX UI — run with backend via npm run dev",
    "scripts": {
        "dev": "concurrently -n api,web -c blue,magenta \"npm run dev:api\" \"npm run dev:web\"",
        "dev:web": "vite",
        "dev:api": "cross-env DEV_API_ONLY=1 npm run dev:server --prefix ../MindCoder",
        "build": "vite build",
        "start": "npm run start --prefix ../MindCoder",
        "preview": "vite preview"
    },
    "dependencies": {
        "@monaco-editor/react": "^4.7.0",
        "@radix-ui/react-slot": "^1.1.0",
        "@radix-ui/react-toggle": "^1.1.0",
        "@radix-ui/react-toggle-group": "^1.1.0",
        "class-variance-authority": "^0.7.0",
        "framer-motion": "^12.38.0",
        "lenis": "^1.3.21",
        "lucide-react": "^0.453.0",
        "monaco-editor": "^0.52.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-router-dom": "^6.8.1",
        "socket.io-client": "^4.8.3"
    },
    "devDependencies": {
        "@types/react": "18.2.0",
        "@types/react-dom": "18.2.0",
        "@vitejs/plugin-react": "4.3.4",
        "concurrently": "^9.2.0",
        "cross-env": "^7.0.3",
        "esbuild": "0.25.5",
        "globals": "15.12.0",
        "tailwindcss": "3.4.16",
        "vite": "^5.4.19"
    }
}
